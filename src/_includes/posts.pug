---
layout: default
prism: true
permalink: #{filters.slugify( title )}
---
div(class="container max-w-4xl mt-6 px-6")
    div(class="pb-5 mb-5 border-b border-gray-100")
        h1(class="font-bold text-4xl") #{title}
        p(class="text-center text-base leading-6 font-thin text-gray-500") Published 
            time #{ filters.readableDate(date) } 
            | by 
            a.underline(href="/about") #{ settings.author }
    | !{ filters.image({ src: thumbnail, alt: thumbnaildesc, lazy: false}) }
    article(class="prose lg:prose-xl mx-auto dark:prose-invert") 
        | !{ content }
