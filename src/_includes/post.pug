---
layout: default.pug
prism: true
permalink: #{filters.slugify( title )}
---
div(class="container max-w-5xl mt-6 px-6")
    div(class="pb-5 mb-5 border-b border-gray-100")
        h1(class="font-bold text-4xl") #{title}
        p(class="text-center text-base leading-6 font-thin text-gray-500 my-3") Published 
            time #{ filters.readableDate(date) } 
            | by 
            a.underline(href="/about") #{ settings.author }
        p.text-center= filters.emojiReadTime(content)
    div(class="hero mb-5")
        | !{ filters.image({ src: thumbnail, alt: thumbnaildesc, lazy: false, _class: "rounded-3xl", height: "25em", width:"100%", label: true  }) }
    article(class="prose lg:prose-lg mx-auto dark:prose-invert") 
        | !{ content }
